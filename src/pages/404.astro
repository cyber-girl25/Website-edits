---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404 - System Not Found">
  <script is:inline>
    // If they got lost inside the docs, instantly redirect them to the docs homepage
    if (window.location.pathname.startsWith('/docs')) {
      window.location.replace('/docs/');
    }
  </script>

  <main class="flex flex-col items-center justify-center h-screen bg-[#0f0f13] text-gray-300 font-mono">
    <h1 class="text-6xl text-red-500 font-bold mb-4">[404]</h1>
    <p class="text-xl">Payload dropped. You are lost in the mainframe.</p>
    <a href="/" class="mt-8 px-4 py-2 border border-green-500 text-green-500 hover:bg-green-500 hover:text-black transition-colors">
      Return to idktheflag.sh
    </a>
  </main>
</Layout>
